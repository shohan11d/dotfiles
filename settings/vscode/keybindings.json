[
  // open recent files/folders
  {
    "key": "alt+p",
    "command": "workbench.action.openRecent",
  },

  // kill terminal instance
  {
    "key": "delete",
    "command": "workbench.action.terminal.kill",
    "when": "terminalFocus",
  },
  {
    "key": "ctrl+shift+n",
    "command": "workbench.action.terminal.toggleTerminal",
    "when": "terminal.active",
  },
  // navigate forward
  {
    "key": "ctrl+,",
    "command": "workbench.action.navigateForward",
    "when": "canNavigateForward",
  },
  // navigate back
  {
    "key": "ctrl+h",
    "command": "workbench.action.navigateBack",
    "when": "canNavigateBack",
  },
  // open settings changed from c-, to c-. because c-h, c-, bind to navigate back and forward
  {
    "key": "ctrl+.",
    "command": "workbench.action.openSettings",
  },

  // unbind: conflict with c+p vscode command
  {
    "key": "ctrl+p",
    "command": "-extension.vim_ctrl+p",
    "when": "editorTextFocus && vim.active && vim.use<C-p> && !inDebugRepl || vim.active && vim.use<C-p> && !inDebugRepl && vim.mode == 'CommandlineInProgress' || vim.active && vim.use<C-p> && !inDebugRepl && vim.mode == 'SearchInProgressMode'",
  },
  // unbind: conflict with c+i vscode command which triggest ai code action
  {
    "key": "ctrl+i",
    "command": "-extension.vim_ctrl+i",
    "when": "editorTextFocus && vim.active && vim.use<C-i> && !inDebugRepl",
  },
]
