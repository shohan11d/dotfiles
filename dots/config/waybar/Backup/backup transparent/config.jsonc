{
  "position": "bottom",
  "modules-left": ["hyprland/workspaces"],
  "modules-center": [
    "custom/launcher",
    "custom/browser",
    "custom/files",
    "custom/gemini",
    "custom/special-workspace",
    "custom/monitor-rotate",
    "custom/code",
  ],
  "modules-right": [
    "group/tray-expander",
    "clock",
    "pulseaudio",
    "network",
    "custom/power",
  ],

  "hyprland/workspaces": {
    "format": "{name}",
    "persistent-workspaces": {
      "*": 5, // 5 workspaces by default on every monitor
    },
  },
  "custom/launcher": {
    "format": "νΘΞ",
    "on-click": "vicinae toggle",
    "on-click-right": "pkill waybar && waybar &",
    "tooltip": false,
  },

  "custom/browser": {
    "interval": 0,
    "format": "οâ©",
    "on-click": "google-chrome-stable",
    "on-click-right": "pkill waybar && waybar &",
    "tooltip": false,
  },

  "custom/files": {
    "interval": 0,
    "format": "σΑâ™",
    "on-click": "nautilus --new-window",
    "on-click-right": "pkill nautilus || nautilus",
    "tooltip": false,
  },

  "custom/gemini": {
    "interval": 0,
    "format": "σ±ä΅",
    "on-click": "google-chrome-stable https://gemini.google.com",
    "on-click-right": "hyprctl reload",
    "tooltip": false,
  },

  "custom/special-workspace": {
    "interval": 0,
    "format": "σ±üΜ",
    "on-click": "hyprctl dispatch togglespecialworkspace scratch",
    "on-click-right": "hyprctl reload",
    "tooltip": false,
  },

  "custom/monitor-rotate": {
    "interval": 0,
    "format": "ο³à",
    "on-click": "hyprctl keyword monitor 'HDMI-A-2,1920x1080@120,0x0,1' && hyprctl keyword monitor 'HDMI-A-3,1920x1080@100,-1080x0,1,transform,3'",
    "on-click-right": "hyprctl reload",
    "tooltip": false,
  },

  "custom/code": {
    "interval": 0,
    "format": "σΑ®û",
    "on-click": "code",
    "on-click-right": "windsurf",
    "tooltip": false,
  },

  "custom/expand-icon": {
    "format": "ο¹™",
    "tooltip": false,
    "on-scroll-up": "",
    "on-scroll-down": "",
    "on-scroll-left": "",
    "on-scroll-right": "",
  },

  "group/tray-expander": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 600,
      "children-class": "tray-group-item",
    },
    "modules": ["custom/expand-icon", "tray"],
  },

  "clock": {
    "format": "{:L%A,%I:%M}",
    "format-alt": "{:L%d-%B}",
    "tooltip": false,
    "on-click-right": "omarchy-launch-floating-terminal-with-presentation omarchy-tz-select",
  },

  "pulseaudio": {
    "format": "{volume}%",
    "on-click": "pavucontrol",

    "on-click-right": "pactl set-sink-volume @DEFAULT_SINK@ 50%",
    "tooltip-format": "Playing at {volume}%",
    "tooltip": false,
    "scroll-step": 10,
    "format-muted": "νΜ®",
    "format-icons": {
      "headphone": "οÄΞ",
      "headset": "οÄΞ",
      "default": ["σ±É™", "10", "σΑΣΓ", "σΑΣΘ", "σΑΣΞ"],
    },
  },

  "network": {
    "format-icons": ["σΑΛ·", "σΑΛü", "σΑΛΔ", "σΑΛΞ", "σΑΛ®"],
    "format": "{icon}",
    "format-wifi": "{icon}",
    "format-ethernet": "σΑë©",
    "format-disconnected": "σ±•Θ",
    "tooltip-format-wifi": "{essid} ({frequency} GHz)\nβ΅Θ{bandwidthDownBytes}  β΅Γ{bandwidthUpBytes}",
    "tooltip-format-ethernet": "β΅Θ{bandwidthDownBytes}  β΅Γ{bandwidthUpBytes}",
    "tooltip-format-disconnected": "Disconnected",
    "interval": 3,
    "spacing": 1,
    "on-click": "omarchy-launch-wifi",
  },

  "custom/power": {
    "interval": 0,
    "format": "νô≤",
    "tooltip": false,
    "on-click": "systemctl poweroff",
    "on-click-right": "systemctl reboot",
  },
}
